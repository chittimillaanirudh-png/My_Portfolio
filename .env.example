# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_ID=admin
ADMIN_PASSWORD=adminpassword

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=yoursecretjwttokenhere

# ── EmailJS ───────────────────────────────────────────────────────────────────
EMAILJS_SERVICE_ID=your_emailjs_service_id_here
EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# ── CORS (backend only — set this on Railway/Render) ──────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Example: https://your-app.vercel.app,https://preview-branch.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Frontend API URL (set this in Vercel Environment Variables) ───────────────
# The public URL of your deployed backend (Railway, Render, etc.).
# Leave blank for local development — Vite's proxy handles it automatically.
# Example: https://my-portfolio-backend.railway.app
VITE_API_URL=https://your-backend.railway.app
